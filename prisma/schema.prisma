// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum OtcUserType {
  individual
  business
}

enum OtcContactMethod {
  whatsapp
  email
  call
}

enum OtcTradeType {
  crypto_to_fiat
  fiat_to_crypto
  fiat_to_fiat
}

enum OtcStatus {
  pending // Just submitted, awaiting review
  in_review // OTC desk is reviewing
  contacted // Team has reached out to the user
  completed // Trade completed successfully
  cancelled // Request cancelled
}

enum Status {
  PENDING
  ACTIVE
  NOT_ACTIVE
}

enum Portfolio {
  FOUNDER
  SHAREHOLDER
  DIRECTOR
}

enum ProductStatus {
  PUBLISHED
  DRAFTED
}

enum AccountType {
  BUSINESS
  INDIVIDUAL
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  CREATED
  PENDING
  REJECTED
  UNDER_REVIEW
  DEACTIVATED
  DISMISSED
}

enum SwapStatus {
  AWAITING_TRANSFER
  CREATED
  PROCESSING
  COMPLETED
  FAILED
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELED
}

enum CampaignType {
  EMAIL
  PUSH
  SMS
}

enum NotificationType {
  ORDER
  GENERAL
  PRODUCT
  STORE
  TOPUP
}

enum BroadcastMode {
  PUSH
  EMAIL
  SMS
}

enum BroadcastRecipient {
  ALL
  SHOPPERS
  MALLS
}

enum BroadcastStatus {
  PUBLISHED
  DRAFTED
}

enum walletType {
  CRYPTO
  FIAT
}

enum currencyType {
  CRYPTO
  FIAT
}

enum TransactionStatus {
  SUCCESSFUL
  PENDING
  FAILED

  PROCESSING
  COMPLETED
  REVERSED
  CANCELLED
  EXPIRED
}

enum TransactionPaymentMethod {
  WALLET
  TRANSFER
}

enum ActivityType {
  REFERRAL
  NOTIFICATION
}

enum ActivityStatus {
  CLOSED
  OPEN
}

enum TransactionType {
  FAILED
  TRANSFER
  CREDIT_PAYMENT
  DEBIT_PAYMENT
  FIAT_DEPOSIT
  FIAT_WITHDRAWAL
  EXCHANGE_BUY
  EXCHANGE_SELL

  P2P_TRANSFER // user to user
  BANK_DEPOSIT // bank to wallet
  BANK_WITHDRAWAL // wallet to bank
  CRYPTO_DEPOSIT // blockchain to wallet
  CRYPTO_WITHDRAWAL // wallet to blockchain
  CURRENCY_EXCHANGE // NGN to USDT etc.
  FEE_CHARGE
  REFUND
  REVERSAL
  ADJUSTMENT
}

enum AwaitingStatus {
    PENDING
    CONFIRMED
    PROCESSING
    CONFIRMING
    SUCCESS
    REFUNDED
    FAILED
    EXPIRED
}

enum PostDetailStatus {
  PENDING
  SUCCESS
  REFUNDED
  FAILED
  EXPIRED
}

enum TwoFactorAuthenticationMethod {
  EMAIL_OTP
  SMS_OTP
  THIRD_PARTY_AUTHENTICATOR
}

enum AdvertStatus {
  PUBLISHED
  DRAFTED
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED
  STUDENT
  RETIRED
}

enum SourceOfFunds {
  SALARY
  INVESTMENTS
  SAVINGS
  FAMILY
  OTHER
}

enum AccountPurpose {
  PERSONAL_USE
  BUSINESS
  INVESTMENT
  OTHER
}

enum GovernmentIdType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
  RESIDENCE_PERMIT
}

enum ProofOfAddressType {
  UTILITY_BILL
  BANK_STATEMENT
  GOVERNMENT_LETTER
  LEASE_AGREEMENT
}

enum beneficiaryType {
  USER
  CRYPTO
  BANK
}

enum bankDetailStatus {
  PENDING
  ACTIVE
}

enum WalletStatus {
  ACTIVE
  IDLE
  DORMANT
  ARCHIVED
}

enum VendorStatus {
  PENDING      // applied, awaiting review
  APPROVED     // can create orders
  REJECTED     // denied
  SUSPENDED    // was approved, now blocked
}

model OtcRequest {
  id          String      @id @default(uuid())
  fullName    String
  email       String
  phoneNumber String
  userType    OtcUserType

  preferredContact OtcContactMethod

  tradeType       OtcTradeType
  fromCurrency    String
  toCurrency      String
  amount          Decimal      @db.Decimal(20, 8)
  additionalNotes String?

  // ── Receiving Details ──────────────────────────
  // Stored as a JSON array of { label: string, value: string } pairs.
  // Examples:
  //   Crypto → Fiat: [{ label: "Bank Name", value: "Zenith Bank" }, { label: "Account Number", value: "0123456789" }]
  //   Fiat → Crypto: [{ label: "Wallet Address", value: "0x1a2b..." }, { label: "Network", value: "TRC-20" }]
  //   Fiat → Fiat:   [{ label: "IBAN", value: "GB29NWBK..." }, { label: "SWIFT / BIC", value: "NWBKGB2L" }]
  receivingDetails Json @default("[]")

  idDocumentUrl     String?
  proofOfAddressUrl String?
  invoiceUrl        String? // Required only for business accounts

  status     OtcStatus @default(pending)
  adminNotes String? // Internal notes from OTC desk

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("otc_requests")
}

model VendorApplication {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id])
  status      VendorStatus @default(PENDING)
    
  // Application details
  businessName    String?
  businessType    String?   // individual, business, institution
  country         String
  monthlyVolume   String?   // estimated volume
  description     String?   // why they want to be a vendor
    
  // Review
  reviewedBy      String?   // admin userId
  reviewedAt      DateTime?
  rejectionReason String?
  suspensionReason String?
    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  @@index([status])
}



model Rating {
  id        Int      @id @default(autoincrement())
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  productId String
  userId    String
}

model User {
  id           String      @id @default(cuid())
  authId       String?     @unique
  firstName    String      @db.VarChar(255)
  lastName     String      @db.VarChar(255)

  legalFirstName  String?
  legalLastName   String?
  legalNameVerifiedAt DateTime?

  BusinessName String?
  referralId   String?
  referreeId   String?
  email        String      @unique @db.VarChar(255)
  userStatus   UserStatus  @default(CREATED)
  type         AccountType @default(INDIVIDUAL)
  photoUrl     String?     @db.VarChar(500)
  phoneNumber  String?

  country    String?
  address    String?
  city       String?
  state      String?
  postalCode String?

  password          String?  @db.VarChar(500)
  emailVerified     Boolean? @default(false)
  accountVerified   Boolean? @default(false)
  otpCode           String?
  otpCodeUsed       Boolean  @default(false)
  otpCodeExpiryTime String?

  // ✅ Bank details
  bvnSubmitted Boolean @default(false)
  bvnVerified  Boolean @default(false)
  bvn          String?
  bvnDetails   Json?

  bankId            String?
  bankCode          String?
  bankAccountNumber String?

  qorepayCustomerId       String?
  qorepayVirtualAccountId String?
  qorepayStatus           String?
  qorepayProvisionedAt    DateTime?


  // ✅ ACCESS PIN (for anonymous orders - 6 digits)
  accessPin          String? // Hashed PIN
  pinExpiresAt       DateTime? // For regenerated PINs
  pinAttempts        Int       @default(0)
  pinLockedUntil     DateTime?
  pinGeneratedAt     DateTime? // Last PIN generation time
  pinGenerationCount Int       @default(0) // Daily counter

  // ✅ TRANSACTION PIN (for transfers - 4 digits)
  transactionPin               String? // Hashed 4-digit PIN
  transactionPinSalt           String? // Salt for transaction PIN
  transactionPinCreatedAt      DateTime?
  transactionPinLastChangedAt  DateTime?
  transactionPinFailedAttempts Int       @default(0)
  transactionPinLockedUntil    DateTime?

  fernUserId                    String?
  fernKycLink                   String?
  userBanks                     UserBank[]
  notifications                 Notification[]
  transactions                  Transaction[]
  wallet                        Wallet[]
  notificationSetting           NotificationSetting?
  twoFactorEnabled              Boolean                       @default(false)
  twoFactorAuthenticationMethod TwoFactorAuthenticationMethod @default(EMAIL_OTP)
  twoFactorAuthenticationSecret String?
  isDeactivated                 Boolean                       @default(false)
  deactivationReason            String?
  isAnonymous                   Boolean                      @default(false)
  realEmail                     String?

  isVendor        Boolean @default(false)
  vendorApplication VendorApplication?


  kycTier          Int       @default(0)
  kycTier1At       DateTime?
  kycTier2At       DateTime?
  kycTier3At       DateTime?
 
  dojahBvnRef      String?
  dojahNinRef      String?
  dojahIdRef       String?
  dojahLivenessRef String?
 
  kycUsages        KycUsage[]
  kycVerifications KycVerification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  Order           Order[]
  PendingActivity PendingActivity[]
  Card            Card?
  fiatAccount     fiatAccount[]
  cryptoAccount   cryptoAccount[]
  Swap            Swap[]
  userKyc         UserKyc[]         @relation("UserKycToUser")

  Awaiting       Awaiting[]
  postDetails    postDetails[]
  beneficiaries  beneficiary[]
  transfers      TransferRequest[]
  PinAttempt     PinAttempt[]
  VirtualAccount VirtualAccount[]

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([userStatus]) // Fast status lookups
  @@index([type]) // Fast type lookups
  @@index([emailVerified]) // For verification checks
  @@index([accountVerified]) // For verification checks
  @@index([createdAt]) // For time-based queries
  @@index([phoneNumber]) // For phone lookups
}

// ✅ Temporary table for new users (before account creation)
model TempUser {
  id                 String   @id @default(cuid())
  email              String   @unique
  phoneNumber        String
  accessPin          String // Hashed PIN
  pinExpiresAt       DateTime // Always has expiry
  pinGeneratedAt     DateTime @default(now())
  pinGenerationCount Int      @default(1)

  createdAt DateTime @default(now())

  @@index([phoneNumber])
}

model PinAttempt {
  id        String   @id @default(uuid())
  userId    String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserKyc {
  id                      String   @id @default(uuid())
  firstName               String
  lastName                String
  phoneNumber             String
  dateOfBirth             DateTime
  employmentStatus        String
  mostRecentOccupation    String?
  sourceOfFunds           String
  accountPurpose          String
  expectedMonthlyPayments String
  isIntermediary          Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  // Address relation (one-to-one)
  addressId String  @unique
  address   Address @relation(fields: [addressId], references: [id], name: "UserKycToAddress")

  // Documents relation (one-to-one)
  documentsId String    @unique
  documents   Documents @relation(fields: [documentsId], references: [id], name: "UserKycToDocuments")

  // User relation (many-to-one)
  userId String
  user   User   @relation(fields: [userId], references: [id], name: "UserKycToUser")

  @@index([userId])
}

model Address {
  id                  String   @id @default(uuid())
  streetLine1         String
  city                String
  stateRegionProvince String
  postalCode          String
  countryCode         String   @db.Char(3)
  userKyc             UserKyc? @relation("UserKycToAddress")
}

model Documents {
  id String @id @default(uuid())

  // Identity relation (one-to-one)
  identityId String   @unique
  identity   Identity @relation(fields: [identityId], references: [id], name: "DocumentsToIdentity")

  // UserKyc relation (one-to-one)
  userKyc UserKyc? @relation("UserKycToDocuments")
}

model Identity {
  id               String     @id @default(uuid())
  type             String
  countryCode      String     @db.Char(3)
  documentIdNumber String
  issuanceDate     DateTime
  expirationDate   DateTime
  frontIdImage     String?
  documents        Documents? @relation("DocumentsToIdentity")
}

model Swap {
  id        String     @id @default(cuid())
  status    SwapStatus @default(CREATED)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  sourceCurrency      String
  destinationCurrency String

  rate              Decimal?
  sourceAmount      Decimal?
  destinationAmount Decimal?
  fee               Decimal?
}

model Bank {
  id       String  @id @default(cuid())
  name     String
  slug     String
  code     String
  country  String
  currency String?

  address    String?
  postalCode String?
  state      String?
  city       String?

  userBanks UserBank[]
  createdAt DateTime   @default(now())
}

model UserBank {
  id            String   @id @default(cuid())
  accountNumber String
  accountName   String
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bankId        String
  bank          Bank     @relation(fields: [bankId], references: [id])
  createdAt     DateTime @default(now())
}

model beneficiary {
  id     String          @id @default(cuid())
  userId String
  ISO    String
  chain  String?
  type   beneficiaryType

  bank   Json?
  crypto Json?
  user   Json?

  userData  User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model TransferRequest {
  id             String          @id @default(uuid())
  idempotencyKey String          @unique
  type           beneficiaryType

  bank   Json?
  crypto Json?
  vyre   Json?

  currencyId String
  amount     Decimal

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status       String // PENDING, PROCESSING, COMPLETED, FAILED
  reference    String? // reference once processed
  createdAt    DateTime  @default(now())
  expiresAt    DateTime? // Auto-cleanup old records
  completedAt  DateTime?
  failedAt     DateTime?
  errorMessage String?

  @@index([userId, createdAt])
  @@index([status])
}

model fiatAccount {
  id            String @id @default(cuid())
  name          String
  bank          String
  accountNumber String
  currency      String
  method        String
  country       String

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model cryptoAccount {
  id               String   @id @default(cuid())
  name             String
  cryptoWalletType String
  chain            String
  address          String
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  createdAt        DateTime @default(now())
}

model NotificationSetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  emailNotification Boolean
  pushNotification  Boolean
  smsNotification   Boolean
  createdAt         DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  type      NotificationType @default(GENERAL)
  title     String?
  content   String
  createdAt DateTime         @default(now())
}

model Transaction {
  id                String            @id @default(cuid())
  walletId          String?
  userId            String?
  orderId           String?
  currency          String?
  user              User?             @relation(fields: [userId], references: [id])
  wallet            Wallet?           @relation(fields: [walletId], references: [id])
  reference         String?
  amount            Decimal           @db.Decimal(20, 8)
  status            TransactionStatus
  type              TransactionType
  description       String
  platformFeeAmount Decimal?          @db.Decimal(20, 8)
  createdAt         DateTime          @default(now())
  metadata          Json?

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([userId])                          // Fast user lookups
  @@index([walletId])                        // Fast wallet lookups
  @@index([status])                          // Fast status lookups
  @@index([type])                            // Fast type lookups
  @@index([reference])                       // For reference lookups
  @@index([userId, status])                  // Compound for user transactions
  @@index([createdAt])                       // For time-based queries
  @@index([userId, createdAt(sort: Desc)])   // For recent user transactions
}

model Currency {
  id   String       @id @default(cuid())
  type currencyType @default(CRYPTO)

  name        String
  ISO         String
  chain       String?
  imgUrl      String?
  chainImgUrl String?
  flagEmoji   String?

  tatumChain String?

  isStablecoin Boolean       @default(false)
  createdAt    DateTime      @default(now())
  Wallet       Wallet[]
  basePairs    Pair[]        @relation("baseCurrency")
  quotePairs   Pair[]        @relation("quoteCurrency")
  Awaiting     Awaiting[]
  postDetails  postDetails[]

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([ISO]) // Fast ISO lookups
  @@index([type]) // Fast type lookups
  @@index([chain]) // For chain-based queries
  @@index([isStablecoin]) // For filtering stablecoins
}

model Wallet {
  id String @id @default(cuid())

  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  currencyId String?
  currency   Currency? @relation(fields: [currencyId], references: [id])

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now())
  Tatum_customerId   String
  accountingCurrency String
  depositAddress     String?
  subscriptionId     String?
  gasPumpAddress     GasPumpAddress?

  destinationTag String?
  derivationKey  Int?
  frozen         Boolean

  qorepay_customerId String?

  accountBalance   Decimal @default(0.00) @db.Decimal(20, 8)
  availableBalance Decimal @default(0.00) @db.Decimal(20, 8)

  status           WalletStatus @default(ACTIVE)
  lastUsedAt       DateTime?
  pooled           Boolean      @default(false)

  

  Transaction Transaction[]
  Block       Block[]
  basePairs   Pair[]        @relation("BaseWallet")
  quotePairs  Pair[]        @relation("QuoteWallet")
  Awaiting    Awaiting[]
  postDetails postDetails[]

  bankDetails bankDetails[]
  SweepLogs   SweepLog[]

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([userId]) // Fast user lookups
  @@index([currencyId]) // Fast currency lookups
  @@index([depositAddress]) // For deposit tracking
  @@index([userId, currencyId]) // Compound for user wallets
  @@index([frozen]) // For filtering frozen wallets
}

model bankDetails {
  id             String           @id @default(uuid())
  customer_id    String?
  account_number String?
  account_name   String?
  bank_name      String?
  status         bankDetailStatus @default(PENDING)

  walletId String @unique
  wallet   Wallet? @relation(fields: [walletId], references: [id])
}

model SweepLog {
  id          String   @id @default(cuid())
  walletId    String
  userId      String
  depositTxId String   @unique // prevents double processing
  sweepTxId   String?
  amount      String
  stablecoin  String
  chain       String
  status      String // QUEUED | PROCESSING | SUCCESS | FAILED
  error       String?
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@index([depositTxId])
}

model GasPumpLog {
  id           String   @id @default(cuid())
  chain        String
  ownerAddress String
  nextIndex    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses GasPumpAddress[]

  @@unique([chain, ownerAddress])
  @@index([chain])
}

model GasPumpAddress {
  id             String   @id @default(cuid())
  chain          String
  ownerAddress   String
  depositAddress String   @unique
  index          Int
  walletId       String?  @unique
  activated      Boolean  @default(false)
  activatedTxId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gasPumpLog GasPumpLog @relation(fields: [chain, ownerAddress], references: [chain, ownerAddress])
  wallet     Wallet?    @relation(fields: [walletId], references: [id])

  @@unique([chain, index]) // same chain can't reuse an index
  @@index([chain])
  @@index([walletId])
  @@index([depositAddress])
  @@index([activated])
}

model Order {
  id            String    @id @default(cuid())
  type          OrderType @default(BUY)
  blockId       String?
  userId        String?
  pairId        String
  amountMinimum Decimal   @default(0.00) @db.Decimal(20, 8)
  user          User?     @relation(fields: [userId], references: [id])
  pair          Pair      @relation(fields: [pairId], references: [id])
  block         Block?    @relation(fields: [blockId], references: [id])
  amount        Decimal   @db.Decimal(20, 8)
  version       Int       @default(0)

  amountProcessed Decimal @default(0.0)
  amountReserved  Decimal @default(0) @db.Decimal(20, 8)

  percentageProcessed Decimal     @default(0.0) @db.Decimal(20, 2)
  price               Decimal     @db.Decimal(20, 8)
  status              OrderStatus @default(OPEN)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  isSynthetic         Boolean     @default(false)
  liquiditySource     String? // 'QUIDAX' — data value only, provider-agnostic naming elsewhere
  liquidityKey        String?     @unique // prevents duplicate synthetic orders on upsert
  metadata            Json?

  Awaiting            Awaiting[]
  OrderLog            OrderLog[]

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([userId]) // Fast user lookups
  @@index([pairId]) // Fast pair lookups
  @@index([status]) // Fast status lookups
  @@index([type]) // Fast type lookups
  @@index([userId, status]) // Compound for user orders
  @@index([pairId, status]) // For pair-based queries
  @@index([createdAt]) // For time-based queries
}

model OrderLog {
  id      String  @id @default(cuid())
  userId  String?
  orderId String?

  baseAmount  Decimal @db.Decimal(20, 8)
  quoteAmount Decimal @db.Decimal(20, 8)
  rate        Decimal @db.Decimal(20, 8)

  baseCurrency  String?
  quoteCurrency String?

  orderType OrderType

  order Order? @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
  metadata  Json?
}

model Pair {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  // Currency Relations
  baseId       String?
  baseCurrency Currency? @relation("baseCurrency", fields: [baseId], references: [id])

  quoteId       String?
  quoteCurrency Currency? @relation("quoteCurrency", fields: [quoteId], references: [id])

  // Wallet Relations
  baseWalletId String?
  baseWallet   Wallet? @relation("BaseWallet", fields: [baseWalletId], references: [id])

  quoteWalletId String?
  quoteWallet   Wallet? @relation("QuoteWallet", fields: [quoteWalletId], references: [id])
  Order         Order[]

  @@index([baseId])
  @@index([quoteId])
  @@index([baseWalletId])
  @@index([quoteWalletId])
  @@index([createdAt])
}

model PendingActivity {
  id          String         @id @default(cuid())
  type        ActivityType   @default(REFERRAL)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  amount      Decimal?       @db.Decimal(20, 8)
  orderAmount Decimal?       @db.Decimal(20, 8)
  status      ActivityStatus @default(OPEN)
  createdAt   DateTime       @default(now())
  executedAt  DateTime
}

model Awaiting {
  id             String  @id @default(cuid())
  triggerAddress String?
  reference      String?
  walletId       String?
  userId         String?
  orderId        String?
  amount         Decimal @db.Decimal(20, 8)

  orderType      OrderType
  status         AwaitingStatus @default(PENDING)
  currencyId     String?
  isSynthetic    Boolean @default(false)

  method String?

  bank_Name           String?
  bank_Account_Number String?
  bank_Account_Name   String?
  bank_expires_At     DateTime?

  bank           Json?
  crypto         Json?
  paymentDetails Json?
  log            Json?

  currency Currency? @relation(fields: [currencyId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  wallet   Wallet?   @relation(fields: [walletId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])

  createdAt   DateTime      @default(now())
  duration    DateTime      @default(now())
  postDetails postDetails[]
  metadata    Json?

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([status]) // Fast status lookups
  @@index([userId]) // Fast user lookups
  @@index([orderId]) // Fast order lookups
  @@index([walletId]) // Fast wallet lookups
  @@index([status, userId]) // Compound for common queries
  @@index([status, orderId]) // For order status checks
  @@index([createdAt]) // For time-based queries
  @@index([duration]) // For expiry checks
  @@index([triggerAddress]) // For webhook lookups
  @@index([reference]) // For payment reference lookups
}

model postDetails {
  id         String  @id @default(cuid())
  awaitingId String?
  walletId   String?
  userId     String?
  orderId    String?
  amount     Decimal @db.Decimal(20, 8)
  currencyId String?

  status PostDetailStatus @default(PENDING)

  persistDetails Boolean @default(true)

  bankCode       String?
  accountNumber  String?
  recipient_Name String?

  chain   String?
  address String?

  awaiting Awaiting? @relation(fields: [awaitingId], references: [id])
  currency Currency? @relation(fields: [currencyId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  wallet   Wallet?   @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())

  // 🚀 PERFORMANCE INDEXES - ADD THESE
  @@index([awaitingId]) // Fast awaiting lookups
  @@index([userId]) // Fast user lookups
  @@index([status]) // Fast status lookups
  @@index([awaitingId, userId]) // Compound for your updateMany query
  @@index([awaitingId, status]) // For status-based awaiting queries
  @@index([createdAt]) // For time-based queries
}

model Card {
  id                String   @id @default(cuid())
