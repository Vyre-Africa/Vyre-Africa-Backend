// // VirtualAccount Service // //

// ==================== ENUMS ====================

enum Virtual_Account_Type {
  STANDARD
  SAVINGS
  ESCROW
  FEE_COLLECTION // internal fee account
  FLOAT // company float account
}

enum AccountStatus {
  ACTIVE
  FROZEN
  SUSPENDED
  CLOSED
}

enum WalletType {
  HD
  KEYPAIR
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  FEE
  REFUND
  REVERSAL
  EXCHANGE
  ADJUSTMENT
}

enum LedgerEntryStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum HoldStatus {
  ACTIVE
  RELEASED
  EXPIRED
  USED
}

enum FeeType {
  PERCENTAGE
  FLAT
  HYBRID // percentage + flat
}

enum ReconciliationStatus {
  PENDING
  MATCHED
  DISCREPANCY
  RESOLVED
}

// Virtual Account System
// Double-entry bookkeeping ledger

model VirtualAccount {
  id         String               @id @default(cuid())
  userId     String
  currency   String // NGN, USD, USDT, BTC, ETH etc.
  type       Virtual_Account_Type @default(STANDARD)
  status     AccountStatus        @default(ACTIVE)
  walletType WalletType           @default(HD)

  // Balances
  balance   Decimal @default(0) @db.Decimal(20, 8)
  frozen    Decimal @default(0) @db.Decimal(20, 8) // locked/pending funds
  available Decimal @default(0) @db.Decimal(20, 8) // balance - frozen

  // Blockchain config  
  xpub       String?
  blockchain String?

  // Metadata
  label    String? // e.g "Main Wallet", "Savings"
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user                  User                    @relation(fields: [userId], references: [id])
  debitEntries          LedgerEntry[]           @relation("DebitAccount")
  creditEntries         LedgerEntry[]           @relation("CreditAccount")
  transactions          VirtualTransaction[]
  blocks                Block[]
  VirtualAccountAddress VirtualAccountAddress[]

  @@unique([userId, currency, type, blockchain])
  @@index([userId])
  @@index([currency])
  @@index([status])
}

model VirtualAccountAddress {
  id               String   @id @default(cuid())
  virtualAccountId String
  blockchain       String
  address          String
  isActive         Boolean  @default(true)
  metadata         Json?
  createdAt        DateTime @default(now())

  // HD wallet fields
  xpub  String?
  index Int?

  // Keypair wallet fields
  encryptedPrivateKey String?
  encryptedMnemonic   String?

  // Token fields
  isToken       Boolean @default(false)
  tokenMint     String?
  tokenSymbol   String?
  tokenStandard String? // SPL, ERC20, TRC20, BEP20

  // Relations
  virtualAccount VirtualAccount @relation(fields: [virtualAccountId], references: [id])

  @@unique([address, blockchain, tokenMint])
  @@index([virtualAccountId])
  @@index([blockchain])
  @@index([address])
}

model XpubIndex {
  id         String   @id @default(cuid())
  xpub       String
  blockchain String
  lastIndex  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([xpub, blockchain])
}

model LedgerEntry {
  id String @id @default(cuid())

  // Double entry - every transaction has a debit and credit
  debitAccountId  String
  creditAccountId String

  amount   Decimal @db.Decimal(20, 8)
  currency String

  type   LedgerEntryType
  status LedgerEntryStatus @default(COMPLETED)

  reference   String  @unique
  description String?
  metadata    Json?

  // Link to parent transaction
  transactionId String?

  createdAt DateTime @default(now())

  // Relations
  debitAccount  VirtualAccount      @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount VirtualAccount      @relation("CreditAccount", fields: [creditAccountId], references: [id])
  transaction   VirtualTransaction? @relation(fields: [transactionId], references: [id])

  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([reference])
  @@index([transactionId])
  @@index([createdAt])
}

model VirtualTransaction {
  id String @id @default(cuid())

  // Parties
  fromAccountId String?
  toAccountId   String?

  // Amount details
  amount    Decimal @db.Decimal(20, 8)
  fee       Decimal @default(0) @db.Decimal(20, 8)
  netAmount Decimal @db.Decimal(20, 8) // amount - fee
  currency  String

  // Exchange rate (for cross-currency transfers)
  fromCurrency    String?
  toCurrency      String?
  exchangeRate    Decimal? @db.Decimal(20, 8)
  convertedAmount Decimal? @db.Decimal(20, 8)

  type   TransactionType
  status TransactionStatus @default(PENDING)

  reference   String  @unique
  externalRef String? // reference from external provider
  description String?

  // For bank withdrawals
  bankDetails Json?
  blockId     String?

  // For crypto
  txHash        String?
  blockchain    String?
  walletAddress String?

  metadata      Json?
  failureReason String?

  // Retry logic
  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Relations
  fromAccount   VirtualAccount? @relation(fields: [fromAccountId], references: [id])
  ledgerEntries LedgerEntry[]
  blocks        Block[]

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([reference])
  @@index([externalRef])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([txHash])
}

model Block {
  id                   String              @id @default(cuid())
  active               Boolean             @default(true)
  walletId             String?
  wallet               Wallet?             @relation(fields: [walletId], references: [id])
  amount               Decimal             @db.Decimal(20, 8)
  description          String
  createdAt            DateTime            @default(now())
  Order                Order[]
  VirtualAccount       VirtualAccount?     @relation(fields: [virtualAccountId], references: [id])
  virtualAccountId     String?
  VirtualTransaction   VirtualTransaction? @relation(fields: [virtualTransactionId], references: [id])
  virtualTransactionId String?
}

model FeeConfig {
  id String @id @default(cuid())

  type     TransactionType
  currency String? // null means applies to all currencies

  // Fee structure
  feeType  FeeType  @default(PERCENTAGE)
  feeValue Decimal  @db.Decimal(10, 4) // percentage or flat amount
  minFee   Decimal? @db.Decimal(20, 8)
  maxFee   Decimal? @db.Decimal(20, 8)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, currency])
  @@index([type])
  @@index([isActive])
}

model ExchangeRate {
  id String @id @default(cuid())

  fromCurrency String
  toCurrency   String
  rate         Decimal @db.Decimal(20, 8)

  provider String? // where the rate came from

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([fromCurrency, toCurrency])
  @@index([createdAt])
  @@index([expiresAt])
}

model LedgerReconciliation {
  id String @id @default(cuid())

  accountId String
  currency  String

  // Expected vs actual
  expectedBalance Decimal @db.Decimal(20, 8)
  actualBalance   Decimal @db.Decimal(20, 8)
  difference      Decimal @db.Decimal(20, 8)

  status ReconciliationStatus @default(PENDING)
  notes  String?

  reconciledAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([accountId])
  @@index([status])
  @@index([createdAt])
}

model KycUsage {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  volumeUsd   Float    @default(0)
  updatedAt   DateTime @updatedAt
 
  @@unique([userId, periodStart])
  @@index([userId])
}
 
model KycVerification {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  type             String
  country          String
  status           String
  dojahRef         String?
  dojahData        Json?
  amlHits          Json?
  flaggedForReview Boolean   @default(false)
  reviewNote       String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
 
  @@index([userId])
  @@index([status])
  @@index([type])
}

model UnreconciledDeposit {
  id         String    @id @default(cuid())
  dvaId      String
  reference  String
  amount     Float
  rawPayload Json
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([dvaId])
  @@index([resolved])
}


